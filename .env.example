NEXT_PUBLIC_API_BASE_URL=https://api.vitaltwin.de
NEXT_PUBLIC_STRIPE_PRICE_ID=
NEXT_PUBLIC_PREMIUM_PRICE_DISPLAY=9,90 €/Monat
# Premium checkout is ON by default. Set to false only to pause/hide Premium sales.
NEXT_PUBLIC_ENABLE_PREMIUM_CHECKOUT=true

# Google Sign-In client ID. Leave empty and the "Mit Google" button is inert
# (no crash) — no fake client ID is ever used.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Not a secret (price IDs only identify a Stripe price object, not credentials).
# Currently unused since checkout uses redirect-based Stripe Checkout Sessions
# rather than Stripe.js/Elements. Documented here for Block 3 (see task spec).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Per-plan, per-interval public price IDs (Block 3: Preisseite/Tarifstruktur).
# Leave empty if that plan+interval isn't sellable yet — the pricing page
# will show "Demnächst verfügbar" instead of a buy button, and the backend
# independently rejects checkout attempts for unconfigured plans either way.
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_FAMILY_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_FAMILY_YEARLY=
